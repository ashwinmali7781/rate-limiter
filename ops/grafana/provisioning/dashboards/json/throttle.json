{
  "title": "Throttle - Rate Limiter",
  "uid": "throttle-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request rate by status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(throttle_requests_total[1m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "p95 decision latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(throttle_request_duration_ms_bucket[5m])) by (le, algorithm))",
          "legendFormat": "{{algorithm}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Requests by algorithm",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(throttle_requests_total) by (algorithm)",
          "legendFormat": "{{algorithm}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Requests by tenant",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(throttle_requests_total) by (tenant)",
          "legendFormat": "{{tenant}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Block rate (%)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(throttle_requests_total{status=\"blocked\"}[5m])) / sum(rate(throttle_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "id": 6,
      "title": "Process memory (RSS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "throttle_process_resident_memory_bytes", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "title": "Event loop lag (p99, seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "throttle_nodejs_eventloop_lag_p99_seconds", "refId": "A" }
      ]
    }
  ]
}
